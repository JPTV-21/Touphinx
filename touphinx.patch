 #include "moc_kitemlistcontroller.cpp"
+
+// ============================================
+// Touphin: 触摸屏专用移动事件处理
+// ============================================
+bool KItemListController::touchMoveEvent(QTouchEvent *event)
+{
+    if (!m_view || !m_isTouchEvent) {
+        return false;
+    }
+
+    const auto touchPoints = event->points();
+    if (touchPoints.isEmpty()) {
+        return false;
+    }
+
+    const QPointF pos = touchPoints.first().position();
+
+    // 长按后拖动 → 框选
+    if (m_dragActionOrRightClick) {
+        const int distance = (pos - m_pressedMousePos).manhattanLength();
+        if (distance >= QApplication::startDragDistance()) {
+            // 长按后拖动，不管是文件上还是空白处，一律框选
+            KItemListRubberBand *rubberBand = m_view->rubberBand();
+            if (!rubberBand->isActive()) {
+                m_oldSelection = m_selectionManager->selectedItems();
+                QPointF startPos = m_pressedMousePos;
+                if (m_view->scrollOrientation() == Qt::Vertical) {
+                    startPos.ry() += m_view->scrollOffset();
+                    if (m_view->itemSize().width() < 0) {
+                        startPos.setX(0);
+                    }
+                } else {
+                    startPos.rx() += m_view->scrollOffset();
+                }
+                rubberBand->setStartPosition(startPos);
+                rubberBand->setEndPosition(startPos);
+                rubberBand->setActive(true);
+                connect(rubberBand, &KItemListRubberBand::endPositionChanged,
+                        this, &KItemListController::slotRubberBandChanged);
+                m_view->setAutoScroll(true);
+            }
+            QPointF endPos = pos;
+            if (m_view->scrollOrientation() == Qt::Vertical) {
+                endPos.ry() += m_view->scrollOffset();
+            } else {
+                endPos.rx() += m_view->scrollOffset();
+            }
+            m_view->rubberBand()->setEndPosition(endPos);
+            m_dragActionOrRightClick = false;
+            return true;
+        }
+        return false;
+    }
+
+    // 短按拖动：走原版鼠标逻辑
+    QGraphicsSceneMouseEvent mouseEvent(QEvent::GraphicsSceneMouseMove);
+    mouseEvent.setPos(pos);
+    mouseEvent.setButtons(Qt::LeftButton);
+    mouseEvent.setModifiers(Qt::NoModifier);
+    return mouseMoveEvent(&mouseEvent, QTransform());
+}
